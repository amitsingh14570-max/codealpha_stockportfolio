def stock_tracker():
    # Hardcoded dictionary for stock prices
    stock_prices = {
        "AAPL": 180,
        "TSLA": 250,
        "GOOGL": 140,
        "MSFT": 350,
        "AMZN": 130
    }
    
    portfolio = {}
    total_investment = 0

    print("--- Simple Stock Portfolio Tracker ---")
    print(f"Available stocks: {', '.join(stock_prices.keys())}")
    
    while True:
        stock_name = input("\nEnter stock ticker (or type 'done' to finish): ").upper()
        
        if stock_name == 'DONE':
            break
            
        if stock_name in stock_prices:
            try:
                quantity = int(input(f"Enter quantity for {stock_name}: "))
                if quantity < 0:
                    print("Quantity cannot be negative.")
                    continue
                
                # Update portfolio
                portfolio[stock_name] = portfolio.get(stock_name, 0) + quantity
                total_investment += stock_prices[stock_name] * quantity
                print(f"Added {quantity} shares of {stock_name}.")
            except ValueError:
                print("Please enter a valid integer for quantity.")
        else:
            print("Stock not found in our current database. Try again.")

    print("\n--- Portfolio Summary ---")
    for stock, qty in portfolio.items():
        print(f"{stock}: {qty} shares @ ${stock_prices[stock]} each = ${qty * stock_prices[stock]}")
    
    print(f"\nTotal Investment Value: ${total_investment}")
    
    # Optional: Save to file
    save = input("Would you like to save this summary to a .txt file? (y/n): ").lower()
    if save == 'y':
        with open("portfolio_summary.txt", "w") as file:
            file.write("--- Portfolio Summary ---\n")
            for stock, qty in portfolio.items():
                file.write(f"{stock}: {qty} shares @ ${stock_prices[stock]} each\n")
            file.write(f"Total Investment Value: ${total_investment}\n")
        print("Saved to portfolio_summary.txt successfully!")

if __name__ == "__main__":
    stock_tracker()
